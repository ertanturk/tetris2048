{
  "workbench.activityBar.location": "top",
  "workbench.tree.indent": 16,
  "workbench.statusBar.visible": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.showIcons": true,
  "zenMode.centerLayout": true,
  "workbench.editor.decorations.badges": false,
  "workbench.editor.highlightModifiedTabs": false,
  "window.title": "${activeEditorShort}",
  "editor.minimap.enabled": false,
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "solid",
  "editor.selectionHighlight": true,
  "editor.folding": false,
  "editor.stickyScroll.enabled": false,
  "editor.renderLineHighlight": "line",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.matchBrackets": "near",
  "editor.wordWrap": "off",
  "workbench.reduceMotion": "on",
  "workbench.editor.showTabs": "none",
  "workbench.editor.labelFormat": "short",
  "editor.occurrencesHighlight": "off",
  "editor.colorDecorators": false,
  "editor.guides.indentation": false,
  "editor.guides.bracketPairs": false,
  "terminal.integrated.defaultProfile.windows": "Ubuntu",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.drawBoldTextInBrightColors": true,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.scrollback": 1500,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.profiles.windows": {
    "Ubuntu": {
      "path": "C:\\Windows\\System32\\wsl.exe"
    }
  },
  "editor.fontLigatures": false,
  "editor.smoothScrolling": false,
  "workbench.list.smoothScrolling": false,
  "workbench.settings.enableNaturalLanguageSearch": false,
  "editor.fontWeight": "400",
  "editor.letterSpacing": 0.5,
  "editor.lineHeight": 1.6,
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "editor.quickSuggestionsDelay": 100,
  "editor.hover.delay": 300,
  "search.searchOnType": false,
  "search.followSymlinks": false,
  "workbench.startupEditor": "none",
  "workbench.editor.restoreViewState": false,
  "remote.WSL.fileWatcher.polling": false,
  "files.simpleDialog.enable": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.git": true,
    "**/coverage": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.ruff_cache": true,
    "**/*.egg-info/**": true,
    "**/.cache/**": true,
    "**/tmp/**": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.pytest_cache": true,
    "**/*.egg-info/**": true
  },
  "python.languageServer": "None",
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.indexing": false,
  "ruff.nativeServer": true,
  "python.testing.pytestArgs": [
    "--color=yes",
    "-v",
    "--tb=short"
  ],
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "python.terminal.activateEnvironment": false,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 8,
    "editor.insertSpaces": false,
    "editor.wordWrapColumn": 100,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "files.trimTrailingWhitespace": true,
  "git.autofetch": false,
  "git.enableSmartCommit": false,
  "editor.aiStats.enabled": false,
  "find-it-faster.general.killTerminalAfterUse": false,
  "find-it-faster.general.batTheme": "base16",
  "chat.agentsControl.enabled": true,
  "window.commandCenter": true,
  "workbench.layoutControl.enabled": false,
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.md": "markdownEditorOptimized.editor",
    "*.markdown": "markdownEditorOptimized.editor",
    "*.mdx": "markdownEditorOptimized.editor",
    "*.mdc": "markdownEditorOptimized.editor",
    "git:/**/*.md": "default",
    "git:/**/*.markdown": "default",
    "git:/**/*.mdx": "default",
    "git:/**/*.mdc": "default",
    "git:**/*.md": "default",
    "git:**/*.markdown": "default",
    "git:**/*.mdx": "default",
    "git:**/*.mdc": "default",
    "chat-editing-text-model:/**/*.md": "default",
    "chat-editing-text-model:/**/*.markdown": "default",
    "chat-editing-text-model:/**/*.mdx": "default",
    "chat-editing-text-model:/**/*.mdc": "default",
    "chat-editing-text-model:**/*.md": "default",
    "chat-editing-text-model:**/*.markdown": "default",
    "chat-editing-text-model:**/*.mdx": "default",
    "chat-editing-text-model:**/*.mdc": "default",
    "\\C:\\Users\\Ertan\\AppData\\Roaming\\Code - Insiders\\User\\settings.json": "default",
    "/C:/Users/Ertan/AppData/Roaming/Code - Insiders/User/settings.json": "default"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/.ruff_cache/**": true
  },
  "editor.experimental.asyncTokenization": true,
  "chat.viewSessions.orientation": "stacked",
  "explorer.autoReveal": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false
}
